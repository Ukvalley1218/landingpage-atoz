# Cache configuration for Netlify, Cloudflare Pages, and similar platforms
# Place this file in your deployment root

# HTML - no cache, always fresh
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# HTML index page
/
  Cache-Control: no-cache, no-store, must-revalidate

# JavaScript bundles (hashed filenames = long cache safe)
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable

# CSS files (hashed filenames = long cache safe)
/assets/*.css
  Cache-Control: public, max-age=31536000, immutable

# Images - long cache (1 year)
/images/*.webp
  Cache-Control: public, max-age=31536000, immutable

/images/*.png
  Cache-Control: public, max-age=31536000, immutable

/images/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/images/*.jpeg
  Cache-Control: public, max-age=31536000, immutable

/images/*.gif
  Cache-Control: public, max-age=31536000, immutable

/images/*.svg
  Cache-Control: public, max-age=31536000, immutable

# Videos - long cache
/images/*.mp4
  Cache-Control: public, max-age=31536000, immutable

# Fonts - long cache
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.woff
  Cache-Control: public, max-age=31536000, immutable

# Favicon
/images/favcon.jpg
  Cache-Control: public, max-age=31536000, immutable